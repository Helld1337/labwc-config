<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>

  <theme>
    <name>old-labwc</name>
    <font name="Sans" size="12" /> 
  </theme>

  <keyboard>
    <keybind key="W-f">
      <action name="Execute" command="fuzzel" />
    </keybind>

    <keybind key="A-Tab">
      <action name="NextWindow" />
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow" />
    </keybind>

    <keybind key="Print">
      <action name="Execute">
        <command>sh -c 'mkdir -p "$HOME/Pictures"; grim -g "$(slurp)" - | swappy -f -'</command>
      </action>
    </keybind>
    
    <keybind key="W-v">
      <action name="Execute">
        <command>sh -c "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"</command>
      </action>
    </keybind>
  </keyboard>
    
</labwc_config>
