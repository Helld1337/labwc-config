<?xml version="1.0" encoding="UTF-8"?>
<labwc_config>

  <theme>
    <name>old-labwc</name>
    <font name="Sans" size="12" /> 
  </theme>

  <keyboard>
    <keybind key="W-f">
      <action name="Execute" command="fuzzel" />
    </keybind>

    <keybind key="A-Tab">
      <action name="NextWindow" />
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow" />
    </keybind>

    <keybind key="Print">
      <action name="Execute">
        <command>sh -c 'mkdir -p "$HOME/Pictures"; fname="$HOME/Pictures/$(date +%Y-%m-%d_%H-%m-%S).png"; grim -g "$(slurp)" "$fname" &amp;&amp; wl-copy &lt; "$fname"'</command>
      </action>
    </keybind>
  </keyboard>

</labwc_config>
